        {
          "path": "table/table.tsx",
          "type": "registry:ui",
          "target": "@aurora/data-display/table.tsx"
        }
      ]
    },
    {
      "name": "data-table",
      "type": "registry:ui",
      "title": "Data Table",
      "description": "Aurora 数据表格组件，基于 TanStack Table",
      "dependencies": ["@tanstack/react-table"],
      "registryDependencies": ["utils", "table", "button"],
      "files": [
        {
          "path": "data-table/data-table.tsx",
          "type": "registry:ui",
          "target": "@aurora/data-display/data-table.tsx"
        }
      ]
    }
  ]
}
