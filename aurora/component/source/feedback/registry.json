        "utils"
      ],
      "files": [
        {
          "path": "toast/toast.tsx",
          "type": "registry:ui",
          "target": "@aurora/feedback/toast.tsx"
        }
      ]
    },
    {
      "name": "sonner",
      "type": "registry:ui",
      "title": "Sonner",
