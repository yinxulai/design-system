      "dependencies": [
        "sonner"
      ],
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "sonner/sonner.tsx",
          "type": "registry:ui",
          "target": "@aurora/feedback/sonner.tsx"
        }
      ]
    }
