{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "items": [
    {
      "name": "progress",
      "type": "registry:ui",
      "title": "Progress",
      "description": "Aurora progress bar component",
      "dependencies": [
        "@radix-ui/react-progress"
      ],
      "registryDependencies": [
        "utils"
      ],
      "files": [
