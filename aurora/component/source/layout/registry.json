{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "items": [
    {
      "name": "surface",
      "type": "registry:ui",
      "title": "Surface",
      "description": "Aurora 核心容器组件，支持 default / muted / accent 三种 tone",
      "registryDependencies": ["utils"],
      "cssVars": {
        "light": {
          "surface-muted-bg": "oklch(0.961 0 0)",
          "surface-accent-border": "oklch(0.09 0 0 / 0.2)"
        },
        "dark": {
          "surface-muted-bg": "oklch(0.205 0 0 / 0.4)",
          "surface-accent-border": "oklch(0.95 0 0 / 0.2)"
        }
      },
      "files": [
        {
          "path": "surface/surface.tsx",
          "type": "registry:ui",
          "target": "@aurora/layout/surface.tsx"
        }
      ]
    },
    {
      "name": "dashboard-shell",
      "type": "registry:ui",
      "title": "Dashboard Shell",
      "description": "Aurora 仪表板外壳，提供最大宽度和响应式内边距",
