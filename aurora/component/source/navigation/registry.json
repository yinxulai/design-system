        {
          "path": "tabs/tabs.tsx",
          "type": "registry:ui",
          "target": "@aurora/navigation/tabs.tsx"
        }
      ]
    },
    {
      "name": "pagination",
      "type": "registry:ui",
      "title": "Pagination",
      "description": "Aurora 分页组件",
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "pagination/pagination.tsx",
          "type": "registry:ui",
          "target": "@aurora/navigation/pagination.tsx"
        }
      ]
    }
  ]
